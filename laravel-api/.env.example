APP_NAME="Trustpilot SOS-Expat"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=trustpilot_sos_expat
DB_USERNAME=trustpilot_user
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=cookie
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
# Dev: leave empty. Prod: set to your domain e.g. sos-expat.com
SESSION_DOMAIN=
# PRODUCTION CHECKLIST:
# APP_ENV=production
# APP_DEBUG=false
# QUEUE_CONNECTION=redis
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true (add to .env in prod)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Dev: use 'sync' (no Redis needed). Prod: use 'redis'
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=trustpilot_

# Redis (production only)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

# OpenAI
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o

# Baileys shared secret (must match baileys-service .env)
BAILEYS_API_KEY=CHANGE_ME_STRONG_SECRET

# Sanctum — allowed origins for React dashboard
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:80

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sos-expat.com"
MAIL_FROM_NAME="${APP_NAME}"
